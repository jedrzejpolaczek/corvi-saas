# Core
DATABASE_URL=sqlite:///./corvi.db
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=please-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=1440

# S3 / MinIO
S3_ENDPOINT_URL=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
